"use client";

import { useState } from "react";
import Link from "next/link";
import { usePathname } from "next/navigation";
import { useWorkspaceRuntime } from "@/app/providers/WorkspaceRuntimeProvider";

export default function WorkspaceTopBar() {
  const {
    runtime,
    organization,
    navigation,
    ready,
  } = useWorkspaceRuntime();

  const pathname = usePathname();

  const organizationId =
    organization?.id ||
    runtime?.activeOrganization?.id;

  const companyName =
    organization?.name ||
    runtime?.activeOrganization?.name ||
    "Workspace";

  const userName =
    runtime?.access?.staff?.name ||
    runtime?.access?.staff?.email ||
    "User";

  const executive =
    navigation?.executive || [];

  const groupedModules =
    navigation?.groupedModules || {};

  const [activeCapability, setActiveCapability] =
    useState(
      executive?.[0]?.name ||
      "Operations"
    );

  if (!ready) {
    return (
      <div className="px-6 py-3 text-white/50 text-sm">
        Loading workspace...
      </div>
    );
  }

  const visibleModules =
    groupedModules[
      activeCapability
    ] || [];

  return (
    <header className="border-b border-white/10 bg-black">

      <div className="flex items-center justify-between px-8 py-5">

        <div>
          <div className="text-4xl font-extralight tracking-[-0.03em] text-white">
            {companyName}
          </div>

          <div className="mt-2 text-[11px] uppercase tracking-[0.35em] text-white/45">
            Synthetic Intelligence OS
          </div>
        </div>

        <div className="text-right">
          <button className="text-base font-light text-white">
            {userName}
          </button>
        </div>

      </div>

      <div className="border-t border-white/10 px-8 py-3">

        <div className="flex flex-wrap gap-3">

          {executive.map((capability) => (

            <button
              key={capability.id}
              onClick={() =>
                setActiveCapability(
                  capability.name
                )
              }
              className={
                activeCapability === capability.name
                  ? "px-4 py-2 rounded-xl bg-[#D6A66A]/20 border border-[#D6A66A]/50 text-[#D6A66A]"
                  : "px-4 py-2 rounded-xl border border-white/10 text-white/60"
              }
            >
              {capability.name}
            </button>

          ))}

        </div>

      </div>

      <div className="border-t border-white/5 px-8 py-3">

        <div className="flex flex-wrap gap-3">

          {visibleModules.map((module) => {

            const moduleId =
              module.id ||
              module.module_id;

            const href =
              `/workspace/${organizationId}/${moduleId}`;

            const active =
              pathname === href ||
              pathname.startsWith(
                href + "/"
              );

            return (
              <Link
                key={moduleId}
                href={href}
                className={
                  active
                    ? "px-4 py-2 rounded-xl border border-[#D6A66A]/50 bg-[#D6A66A]/10 text-[#D6A66A]"
                    : "px-4 py-2 rounded-xl border border-white/10 text-white/70"
                }
              >
                {module.name}
              </Link>
            );
          })}

        </div>

      </div>

    </header>
  );
}
